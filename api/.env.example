# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://recipe_ai:recipe_ai_dev@localhost:5433/recipe_ai_dev

# Redis
REDIS_URL=redis://localhost:6380

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# S3 / MinIO
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=recipe-ai
S3_REGION=us-east-1

# AI — free-first routing (see api/src/lib/invokeLLM.ts)
# Priority for automatic mode: LLM_DEFAULT_PROVIDER + LLM_FALLBACK_PROVIDERS.
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o-mini
GOOGLE_AI_API_KEY=
GEMINI_MODEL_FLASH=gemini-2.0-flash
GEMINI_MODEL_PRO=gemini-1.5-pro
GEMINI_MODEL_FLASH_LITE=gemini-2.5-flash-lite
GROQ_API_KEY=
GROQ_MODEL_DEFAULT=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
OPENROUTER_API_KEY=
OPENROUTER_MODEL_DEFAULT=openrouter/free
LLM_DEFAULT_PROVIDER=gemini
LLM_FALLBACK_PROVIDERS=openai,groq,openrouter
LLM_INTERNET_USE_PRO_THRESHOLD=12000
LLM_INTERNET_PREFER=flash

# Image Services
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Optional — Instagram URL import: Meta Graph `instagram_oembed` needs a token or it returns 400.
# Without it, the server cannot read post captions and import may fail or be low quality.
# Option A — one line (some Docker/panels break the `|` character; use B if import fails):
# FACEBOOK_APP_ACCESS_TOKEN=1234567890123456|your_app_secret_here
# Option B — two lines (recommended on VPS):
# FACEBOOK_APP_ID=1234567890123456
# FACEBOOK_APP_SECRET=your_app_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign-In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# App URLs — APP_URL must be the URL users open in the browser (SPA), used in password-reset links
# Production example: https://app.yourdomain.com (not the API host)
APP_URL=http://localhost:5173
API_URL=http://localhost:3001

# Optional SMTP — password reset (כל חמשת השדות חובה כשמפעילים)
#
# Gmail (תיבה ייעודית + סיסמת אפליקציה, לא סיסמת Gmail רגילה):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-dedicated@gmail.com
# SMTP_PASS=xxxx-app-password-xxxx
# SMTP_FROM=Recipe AI <your-dedicated@gmail.com>
#
# Hostinger Email:
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=
# SMTP_FROM=Recipe AI <noreply@yourdomain.com>
#
# Resend (מומלץ אם SMTP נחסם מה-VPS) — https://resend.com — שליחה דרך HTTPS
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=Recipe AI <onboarding@resend.dev>
