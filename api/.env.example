# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://recipe_ai:recipe_ai_dev@localhost:5433/recipe_ai_dev

# Redis
REDIS_URL=redis://localhost:6380

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# S3 / MinIO
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=recipe-ai
S3_REGION=us-east-1

# AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# Image Services
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign-In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# App URLs (APP_URL = frontend base; used in password-reset email links)
APP_URL=http://localhost:5173
API_URL=http://localhost:3001

# Optional SMTP — password reset (כל חמשת השדות חובה כשמפעילים)
#
# Gmail (תיבה ייעודית + סיסמת אפליקציה, לא סיסמת Gmail רגילה):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-dedicated@gmail.com
# SMTP_PASS=xxxx-app-password-xxxx
# SMTP_FROM=Recipe AI <your-dedicated@gmail.com>
#
# Hostinger Email:
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=
# SMTP_FROM=Recipe AI <noreply@yourdomain.com>
#
# Resend (מומלץ אם SMTP נחסם מה-VPS) — https://resend.com — שליחה דרך HTTPS
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=Recipe AI <onboarding@resend.dev>
