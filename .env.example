# Server
API_PORT=3001
WEB_PORT=8081
NODE_ENV=development

# Database
DB_USER=recipe_ai
DB_PASSWORD=recipe_ai_dev
DB_NAME=recipe_ai_dev
DATABASE_URL=postgresql://recipe_ai:recipe_ai_dev@postgres:5432/recipe_ai_dev

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# S3 / MinIO
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=recipe-ai
S3_REGION=us-east-1

# MinIO
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# AI — InvokeLLM (OpenAI default + Gemini for internet context). See api/src/lib/invokeLLM.ts
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Image Services
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign-In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# App URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3001
