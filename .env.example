# Server
API_PORT=3001
WEB_PORT=8081
NODE_ENV=development

# Database
DB_USER=recipe_ai
DB_PASSWORD=recipe_ai_dev
DB_NAME=recipe_ai_dev
DATABASE_URL=postgresql://recipe_ai:recipe_ai_dev@postgres:5432/recipe_ai_dev

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# S3 / MinIO
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=recipe-ai
S3_REGION=us-east-1

# MinIO
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# AI — free-first routing. See api/src/lib/invokeLLM.ts
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o-mini
GOOGLE_AI_API_KEY=
GEMINI_MODEL_FLASH=gemini-2.0-flash
GEMINI_MODEL_PRO=gemini-1.5-pro
GEMINI_MODEL_FLASH_LITE=gemini-2.5-flash-lite
GROQ_API_KEY=
GROQ_MODEL_DEFAULT=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
OPENROUTER_API_KEY=
OPENROUTER_MODEL_DEFAULT=openrouter/free
LLM_DEFAULT_PROVIDER=gemini
LLM_FALLBACK_PROVIDERS=openai,groq,openrouter
LLM_INTERNET_USE_PRO_THRESHOLD=12000
LLM_INTERNET_PREFER=flash

# Image Services
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign-In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# App URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3001
